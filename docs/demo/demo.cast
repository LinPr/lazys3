70mtoggle the live transfers overlay (newest first, scrollable)\u001b[m\u001b[19X\t\t\t \u00a0\u00a0\u001b[38;2;59;130;246m\u2502\u001b[m\r\n\u001b[38;2;59;130;246m\u2502\u001b[m\u00a0\u00a0\u001b[38;2;221;221;221mT \u001b[13b\u001b[38;2;170;170;170mtransfer history (persistent, across sessions)\u001b[m\u001b[33X\u001b[98`\u00a0\u00a0\u001b[38;2;59;130;246m\u2502\u001b[m\r\n\u001b[38;2;59;130;246m\u2502\u001b[m\u00a0\u00a0\u001b[38;2;221;221;221mx \u001b[13b\u001b[38;2;170;170;170mcancel the most recent running transfer (transfers overlay: the highlighted on\u2026\u001b[m\u00a0\u00a0\u001b[38;2;59;130;246m\u2502\u001b[m\r\n\u001b[38;2;59;130;246m\u2502\u001b[m\u00a0\u00a0\u001b[38;2;221;221;221ml \u001b[13b\u001b[38;2;170;170;170mtoggle dual-pane layout (local \u21c4 remote, needs \u226580 cols)\u001b[m\u001b[23X\t\t\t \u00a0\u00a0\u001b[38;2;59;130;246m\u2502\u001b[m\r\n\u001b[38;2;59;130;246m\u2502\u001b[m\u00a0\u00a0\u001b[38;2;221;221;221mtab \u001b[11b\u001b[38;2;170;170;170mswitch focus between remote and local panes (dual-pane)\u001b[m\u001b[24X\t\t\t \u00a0\u00a0\u001b[38;2;59;130;246m\u2502\u001b[m\r\n\u001b[38;2;59;130;246m\u2502\u001b[m\u00a0\u00a0\u001b[38;2;221;221;221mp \u001b[13b\u001b[38;2;170;170;170mpreview file content (floating overlay, first 256 KiB)\u001b[m\u001b[25X\t\t\t \u00a0\u00a0\u001b[38;2;59;130;246m\u2502\u001b[m\r\n\u001b[38;2;59;130;246m\u2502\u001b[m\u00a0\u00a0\u001b[38;2;221;221;221mm \u001b[13b\u001b[38;2;170;170;170mobject/file metadata (floating overlay; buckets and profiles too)\u001b[m\u001b[14X\t\t \u00a0\u00a0\u001b[38;2;59;130;246m\u2502\u001b[m\r\n\u001b[38;2;59;130;246m\u2502\u001b[m\u00a0\u00a0\u001b[38;2;221;221;221menter / \u2192 \u001b[5b\u001b[38;2;170;170;170mopen selected (profile \u2192 buckets \u2192 objects)\u001b[m\u001b[36X\u001b[98`\u00a0\u00a0\u001b[38;2;59;130;246m\u2502\u001b[m\r\n\u001b[38;2;59;130;246m\u2502\u001b[m\u00a0\u00a0\u001b[38;2;221;221;221mbackspace / \u2190  \u001b[38;2;170;170;170mgo back o